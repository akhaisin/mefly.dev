---
import { resolveIframeSrc, isDevOnly } from '../apps';
import type { App } from '../apps';

interface Props {
  app: App;
}

const { app } = Astro.props;
const href = resolveIframeSrc(app, import.meta.env.DEV)
  ? `/apps/${app.id}`
  : undefined;
const devOnly = isDevOnly(app);
const disabled = !href;
---

{disabled ? (
  <span class="app-icon app-icon--disabled">
    <img src={app.iconUrl} alt={app.label} width="80" height="80" />
    <span>{app.label}</span>
  </span>
) : (
  <a href={href} class:list={['app-icon', devOnly && 'app-icon--dev-only']}>
    <img src={app.iconUrl} alt={app.label} width="80" height="80" />
    <span>{app.label}</span>
    {devOnly && <span class="dev-badge" title="No production deployment yet">dev</span>}
  </a>
)}

<style>
  .app-icon {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.75rem;
    text-decoration: none;
    color: #ccc;
    padding: 1.25rem;
    border-radius: 1.25rem;
    transition: background 0.15s ease;
    position: relative;
  }

  .app-icon:not(.app-icon--disabled):hover {
    background: rgba(255, 255, 255, 0.07);
    color: #fff;
  }

  .app-icon--disabled {
    opacity: 0.35;
    cursor: default;
  }

  .app-icon--dev-only {
    opacity: 0.75;
  }

  img {
    width: 80px;
    height: 80px;
    border-radius: 0.75rem;
  }

  span {
    font-size: 0.8125rem;
    font-family: system-ui, sans-serif;
    letter-spacing: 0.02em;
  }

  .dev-badge {
    position: absolute;
    top: 0.75rem;
    right: 0.75rem;
    font-size: 0.625rem;
    font-family: system-ui, sans-serif;
    letter-spacing: 0.05em;
    text-transform: uppercase;
    background: rgba(255, 200, 0, 0.2);
    color: #ffc800;
    border-radius: 0.25rem;
    padding: 0.1em 0.35em;
    line-height: 1.4;
  }
</style>
