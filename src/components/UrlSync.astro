<script>
  const iframe = document.getElementById('app-iframe') as HTMLIFrameElement | null;
  if (iframe) {
    const iframeOrigin = (() => {
      try {
        return new URL(iframe.src, window.location.origin).origin;
      } catch {
        return null;
      }
    })();

    if (iframeOrigin) {
      let ready = false;
      let lastPolledHash = '';

      function sendHash(hash: string): void {
        if (!ready) return;
        iframe!.contentWindow?.postMessage(
          { type: 'NAVIGATE_TO_HASH', hash: hash.replace(/^#/, ''), timestamp: Date.now() },
          iframeOrigin!,
        );
      }

      iframe.addEventListener('load', () => {
        ready = true;
        if (window.location.hash) sendHash(window.location.hash);
      });

      window.addEventListener('hashchange', () => sendHash(window.location.hash));

      window.addEventListener('message', (event) => {
        if (event.source !== iframe!.contentWindow) return;
        if (event.origin !== iframeOrigin) return;
        if (event.data?.type !== 'HASH_CHANGED') return;

        const incoming: string = event.data.hash ?? '';
        if (!incoming) return;

        const next = incoming.startsWith('#') ? incoming : `#${incoming}`;
        if (window.location.hash !== next) window.location.hash = next;
      });

      // Fallback polling for same-origin / local dev where postMessage is not fired.
      setInterval(() => {
        if (!ready) return;
        try {
          const iframeHash = iframe!.contentWindow!.location.hash;
          if (iframeHash !== lastPolledHash) {
            lastPolledHash = iframeHash;
            if (iframeHash && window.location.hash !== iframeHash) {
              window.location.hash = iframeHash;
            }
          }
        } catch {
          // Expected in cross-origin mode.
        }
      }, 200);
    }
  }
</script>
