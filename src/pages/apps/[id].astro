---
import { apps } from '../../apps';
import type { App } from '../../apps';
import AppEmbed from '../../layouts/AppEmbed.astro';

export function getStaticPaths() {
  return apps.map((app) => ({
    params: { id: app.id },
    props: { app },
  }));
}

interface Props {
  app: App;
}

const { app } = Astro.props;
---

<AppEmbed app={app} />
