---
import type { App } from '../apps';
import { navItemsFor } from '../apps';
import UrlSync from '../components/UrlSync.astro';
import DelegateMenu from '../components/DelegateMenu.astro';
import { MeflyNav } from 'mefly-nav';
import 'mefly-nav/style.css';

interface Props {
  app: App;
}

const { app } = Astro.props;
const isDev = import.meta.env.DEV;
const iframeSrc = isDev ? (app.iframeUrlLocal ?? app.iframeUrl) : app.iframeUrl;
const menuMode = app.menuMode ?? 'host';
const navItems = navItemsFor(app.id, isDev);
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <title>{app.label} — mefly.dev</title>
  </head>
  <body>
    {iframeSrc
      ? <iframe id="app-iframe" src={iframeSrc} title={app.label} allowfullscreen></iframe>
      : <p class="not-implemented">Not implemented yet</p>
    }
    {iframeSrc && app.urlSync && <UrlSync />}
    {menuMode === 'host' && (
      <MeflyNav client:load items={navItems} activeId={app.id} activationMode="hover" />
    )}
    {menuMode === 'delegate' && iframeSrc && (
      <DelegateMenu activeId={app.id} items={navItems} />
    )}
  </body>
</html>

<style>
  html,
  body {
    margin: 0;
    padding: 0;
    height: 100%;
    overflow: hidden;
  }

  iframe {
    display: block;
    width: 100%;
    height: 100%;
    border: none;
  }

  .not-implemented {
    color: #888;
    font-family: system-ui, sans-serif;
    font-size: 1rem;
    margin: auto;
  }
</style>
